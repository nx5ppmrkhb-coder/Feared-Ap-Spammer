local function sendToChat(msg)
    local success, chatChannel = pcall(function() return TextChatService.TextChannels.RBXGeneral end)
    if success and chatChannel then chatChannel:SendAsync(msg) else
        local sayMsg = ReplicatedStorage:FindFirstChild("DefaultChatSystemChatEvents") and ReplicatedStorage.DefaultChatSystemChatEvents:FindFirstChild("SayMessageRequest")
        if sayMsg then sayMsg:FireServer(msg, "All") end
    end
end

local function executeSpam(targetName)
    if not targetName or targetName == "NONE" then return end
    local cmds = {";rocket ", ";balloon ", ";ragdoll ", ";morph ", ";jumpscare "}
    for _, cmd in ipairs(cmds) do sendToChat(cmd .. targetName) task.wait(0.1) end
end

local function getNearestPlayer()
    local closestPlayer, shortestDistance = nil, math.huge
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (LocalPlayer.Character.HumanoidRootPart.Position - player.Character.HumanoidRootPart.Position).Magnitude
                if dist < shortestDistance then closestPlayer, shortestDistance = player, dist end
            end
        end
    end
    return closestPlayer
end

UserInputService.InputBegan:Connect(function(input, processed)
    if not processed and input.KeyCode == Enum.KeyCode.F then
        if MainFrame.Visible then executeSpam(selectedPlayerName) else 
            local t = getNearestPlayer() if t then executeSpam(t.Name) end
        end
    end
end)

local function updateList()
    for _, child in pairs(ScrollingFrame:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
    for _, player in pairs(Players:GetPlayers()) do
        local pBtn = Instance.new("TextButton", ScrollingFrame)
        pBtn.Size = UDim2.new(1, 0, 0, 30); pBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25); pBtn.Text = player.DisplayName
        pBtn.TextColor3 = Color3.fromRGB(255, 255, 255); pBtn.TextXAlignment = Enum.TextXAlignment.Left; pBtn.Font = Enum.Font.GothamBlack; pBtn.TextSize = 8
        Instance.new("UIPadding", pBtn).PaddingLeft = UDim.new(0, 35)
        local avatarImg = Instance.new("ImageLabel", pBtn)
        avatarImg.Size = UDim2.new(0, 24, 0, 24); avatarImg.Position = UDim2.new(0, -30, 0.5, -12); avatarImg.BackgroundTransparency = 1
        avatarImg.Image = Players:GetUserThumbnailAsync(player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
        Instance.new("UICorner", avatarImg).CornerRadius = UDim.new(1, 0); Instance.new("UICorner", pBtn).CornerRadius = UDim.new(0, 6)
        pBtn.MouseButton1Click:Connect(function() 
            for _, btn in pairs(ScrollingFrame:GetChildren()) do if btn:IsA("TextButton") then btn.BackgroundColor3 = Color3.fromRGB(25, 25, 25) end end
            pBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50); selectedPlayerName = player.Name 
            SelectionTag.Text = "SELECTED: " .. player.DisplayName:upper(); SelectionTag.TextColor3 = Color3.fromRGB(255, 75, 75)
        end)
    end
end

