-- --- LOGIC ---
local function sendChat(m)
    local s, c = pcall(function() return TextChatService.TextChannels.RBXGeneral end)
    if s and c then c:SendAsync(m) else
        local e = ReplicatedStorage:FindFirstChild("SayMessageRequest", true)
        if e then e:FireServer(m, "All") end
    end
end

local function runSpam(target)
    if not target or target == "NONE" then return end
    local cmds = {";rocket ", ";balloon ", ";ragdoll ", ";morph ", ";jumpscare "}
    for _, c in ipairs(cmds) do sendChat(c .. target) task.wait(0.1) end
end

local function getClosest()
    local best, dist = nil, math.huge
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (LocalPlayer.Character.HumanoidRootPart.Position - p.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then best, dist = p, d end
        end
    end
    return best
end

local function updateList()
    for _, v in pairs(Scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    for _, p in pairs(Players:GetPlayers()) do
        local b = Instance.new("TextButton", Scroll)
        b.Size = UDim2.new(1, 0, 0, 35)
        b.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
        b.Text = p.DisplayName
        b.TextColor3 = Color3.new(1, 1, 1)
        b.TextXAlignment = Enum.TextXAlignment.Left
        b.Font = Enum.Font.Gotham
        b.TextSize = 10
        Instance.new("UICorner", b)

        -- This padding moves the text further right to prevent headshot overlap
        local padding = Instance.new("UIPadding", b)
        padding.PaddingLeft = UDim.new(0, 40) 

        local img = Instance.new("ImageLabel", b)
        img.Size = UDim2.new(0, 26, 0, 26)
        img.Position = UDim2.new(0, -34, 0.5, -13) -- Positioned relative to the padded text
        img.Image = Players:GetUserThumbnailAsync(p.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size48x48)
        img.BackgroundTransparency = 1
        Instance.new("UICorner", img).CornerRadius = UDim.new(1, 0)

        b.MouseButton1Click:Connect(function()
            selectedPlayerName = p.Name
            SelectionTag.Text = "SELECTED: " .. p.DisplayName:upper()
            SelectionTag.TextColor3 = Color3.fromRGB(255, 100, 100)
        end)
    end
end

-- --- BUTTON EVENTS ---
MiniBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = false
    MiniSpam.Visible = true
    OpenBtn.Visible = true
end)

OpenBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = true
    MiniSpam.Visible = false
    OpenBtn.Visible = false
end)

MainSpam.MouseButton1Click:Connect(function() runSpam(selectedPlayerName) end)
MiniSpam.MouseButton1Click:Connect(function() local t = getClosest() if t then runSpam(t.Name) end end)

UserInputService.InputBegan:Connect(function(i, g)
    if not g and i.KeyCode == Enum.KeyCode.F then
        if MainFrame.Visible then runSpam(selectedPlayerName) 
        else local t = getClosest() if t then runSpam(t.Name) end end
    end
end)

Players.PlayerAdded:Connect(updateList)
Players.PlayerRemoving:Connect(updateList)
updateList()
